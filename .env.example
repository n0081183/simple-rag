# Application (non-secret settings only — API keys go in OS keychain)
SIWZ_DATA_DIR=~/.siwz-rag-lite
SIWZ_LOG_LEVEL=INFO

# LLM — local Ollama (default)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Embeddings cache
HF_HOME=~/.cache/huggingface

# Optional: override KB path (default: $SIWZ_DATA_DIR/kb-active)
# SIWZ_KB_PATH=

# RunPod / Anthropic keys: configure in app Settings (stored via keyring, not here)
